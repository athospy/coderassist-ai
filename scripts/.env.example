# Buffer Publish API
# Get your token at: https://buffer.com/developers/api
BUFFER_ACCESS_TOKEN=your_buffer_access_token_here
BUFFER_INSTAGRAM_PROFILE_ID=your_instagram_profile_id_here

# imgbb — free image hosting so Buffer can reach your local image files
# Get a free API key at: https://api.imgbb.com
IMGBB_API_KEY=your_imgbb_api_key_here

# Default posting time (local time)
POST_HOUR=9
POST_MINUTE=30
